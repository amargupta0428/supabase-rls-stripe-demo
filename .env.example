# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# Use Stripe TEST-MODE keys ONLY.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SECRET — server only. Bypasses RLS. Used ONLY by the Stripe webhook to write
# subscription status. NEVER used for gated user-facing reads.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SECRET — direct Postgres connection (Project Settings → Database →
# Connection string → URI). Used ONLY by `npm run db:setup` to apply schema/seed.
# Not used by the running app. Optional if you apply schema.sql via the SQL Editor.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-REF.supabase.co:5432/postgres

# --- Stripe (TEST MODE ONLY — Developers → API keys) ---
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# The recurring price you created (price_...)
STRIPE_PRICE_ID=price_xxx

# From `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Free trial length (days) applied at checkout
STRIPE_TRIAL_PERIOD_DAYS=7
